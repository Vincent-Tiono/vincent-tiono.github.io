		<Section title='Experience'>
			<div class='flex gap-2'>
				{
					experienceTabs.map((tab, index) => (
						<button
							class='experience-toggle rounded-full border px-4 py-2 text-sm font-medium'
							data-target={tab.id}
							data-active={index === 0 ? 'true' : 'false'}
						>
							{tab.label}
						</button>
					))
				}
			</div>

			{
				experienceTabs.map((tab, index) => (
					<div
						class:list={['experience-panel', index === 0 ? 'block' : 'hidden']}
						data-panel={tab.id}
					>
						<div class='border-l border-border pl-8'>
							{tab.items.map((item) => (
								<article class='relative pb-12 last:pb-0'>
									<span class='absolute -left-[41px] top-1.5 h-4 w-4 rounded-full border-4 border-background bg-muted' />
									<time class='mb-1 font-mono text-sm leading-none tracking-tight text-gray-400 dark:text-gray-500'>
										{item.date}
									</time>
									<h3 class='font-medium dark:text-white'>{item.name}</h3>
									<p class='mt-1 max-w-lg text-sm text-gray-700 dark:text-gray-300'>
										{item.description}
									</p>
								</article>
							))}
						</div>
					</div>
				))
			}
		</Section>

		<script>
			const toggles = document.querySelectorAll('.experience-toggle')
			const panels = document.querySelectorAll('.experience-panel')

			function showPanel(target: string) {
				panels.forEach((panel) => {
					const isActive = panel.getAttribute('data-panel') === target
					panel.classList.toggle('hidden', !isActive)
					panel.classList.toggle('block', isActive)
				})

				toggles.forEach((toggle) => {
					const isActive = toggle.getAttribute('data-target') === target
					toggle.setAttribute('data-active', String(isActive))
				})
			}

			toggles.forEach((toggle) => {
				toggle.addEventListener('click', () => {
					const target = toggle.getAttribute('data-target')
					if (target) showPanel(target)
				})
			})
		</script>

		<Section title='Education'>
			<div class='border-l border-border pl-8'>
				{
					educationItems.map((item) => (
