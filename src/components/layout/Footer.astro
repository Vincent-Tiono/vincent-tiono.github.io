---
import { siteConfig } from '@/site-config'

const footerLinks = [
	{
		label: 'linkedin',
		href: 'https://www.linkedin.com/in/vincent-tiono/'
	},
	{
		label: 'github',
		href: 'https://github.com/Vincent-Tiono'
	}
]

const currentYear = new Date().getFullYear()
---

<footer class='mb-16 w-full'>
	<ul
		class='mt-20 flex flex-col space-x-0 space-y-2 text-neutral-600 md:flex-row md:space-x-4 md:space-y-0 dark:text-neutral-300'
	>
		{
			footerLinks.map((link) => (
				<li>
					<a
						class='flex items-center justify-center transition-all hover:text-neutral-800 dark:hover:text-neutral-100'
						rel='noopener noreferrer'
						target='_blank'
						href={link.href}
						aria-label={`Open ${link.label} profile`}
					>
						<svg
							aria-hidden='true'
							width='12'
							height='12'
							viewBox='0 0 12 12'
							fill='none'
							xmlns='http://www.w3.org/2000/svg'
						>
							<path
								d='M2.07102 11.3494L0.963068 10.2415L9.2017 1.98864H2.83807L2.85227 0.454545H11.8438V9.46023H10.2955L10.3097 3.09659L2.07102 11.3494Z'
								fill='currentColor'
							/>
						</svg>
						<p class='ml-2'>{link.label}</p>
					</a>
				</li>
			))
		}
	</ul>
	<p class='mt-5 text-neutral-600 dark:text-neutral-300'>© Vincent Octavian Tiono {currentYear}</p>
</footer>
